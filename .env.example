# Flutter runtime configuration
# Pass these with --dart-define when running/building the app.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
RAILWAY_BACKEND_URL=https://your-railway-service.up.railway.app

# Auth credential TODOs for Supabase social login setup.
# Configure these in Supabase/Auth provider dashboards; do not ship secrets in client builds.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
APPLE_SERVICES_ID=your-apple-services-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key

# Connector credential TODOs.
NOTION_CONNECTOR_TOKEN=your-notion-token-or-oauth-setup
GMAIL_OAUTH_CLIENT_ID=your-gmail-google-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-gmail-google-oauth-client-secret

# Example:
# flutter run -d macos \
#   --dart-define=SUPABASE_URL=https://your-project.supabase.co \
#   --dart-define=SUPABASE_ANON_KEY=your-anon-key
