<?xml version="1.0" encoding="utf-8"?>
<!--
  Blocks all cleartext (http) traffic in production. Cleartext is permitted only
  for local development hosts (emulator/loopback) so a debug build can still talk
  to a local backend. Any real backend MUST be reached over https.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
